# Port chạy Server Backend (Mặc định: 3000)
PORT=3000

# Connection String kết nối Database PostgreSQL (Đảm bảo đúng port PostgreSQL của bạn)
# Định dạng: postgresql://[user]:[password]@[host]:[port]/[database_name]?schema=public
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5434/it_helpdesk_db?schema=public"

# Cấu hình bảo mật JWT (Nên thay đổi chuỗi ngẫu nhiên có tính bảo mật cao)
JWT_SECRET="YOUR_JWT_SECRET_KEY_HERE"
REFRESH_JWT_SECRET="YOUR_REFRESH_JWT_SECRET_KEY_HERE"
REVIEW_JWT_SECRET="YOUR_REVIEW_JWT_SECRET_KEY_HERE"
JWT_EXPIRES_IN=8h

# Cấu hình Redis
# Cần cài đặt và chạy Redis Server trên Local hoặc Docker trước khi chạy ứng dụng
REDIS_URL=redis://localhost:6379

# Cấu hình Google OAuth
GOOGLE_CLIENT_ID=686516000336-j95tb5of2783ja2tbunjbsshr9evi28l.apps.googleusercontent.com
COMPANY_EMAIL_DOMAIN=mappacific.com.sg,mappacific.com.vn,st.uel.edu.vn,gmail.com

# Cấu hình Mail Server (Nodemailer) dùng gửi khảo sát / thông báo
EMAIL_USER=YOUR_EMAIL@gmail.com
EMAIL_PASS=YOUR_EMAIL_APP_PASSWORD
